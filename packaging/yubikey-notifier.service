[Unit]
Description=YubiKey touch notifier
Documentation=https://github.com/talgarr/yubikey-notifier
After=graphical-session.target
PartOf=graphical-session.target

[Service]
# Privilege comes from the binary's file caps; do not set NoNewPrivileges.
Type=simple
ExecStart=/usr/bin/yubikey-notifier
Environment=YUBIKEY_TRACER_OBJ_PATH=/usr/lib/yubikey-notifier/tracer.bpf.o
Restart=on-failure

[Install]
WantedBy=graphical-session.target
