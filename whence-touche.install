_setcaps() {
    # eBPF caps, so the daemon runs as your user (notifications need the session bus).
    setcap cap_bpf,cap_perfmon,cap_sys_admin+ep /usr/bin/whence-touche
}

post_install() {
    _setcaps
    cat <<'MSG'
==> Enable for your user: systemctl --user enable --now whence-touche.service
==> Needs a notification daemon (dunst/mako/swaync).
MSG
}

post_upgrade() {
    _setcaps
}
